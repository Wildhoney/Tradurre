{
  "name": "reacti8n",
  "version": "0.1.0",
  "description": "Tiny, type-safe, message-first i18n for React with no DSL.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "main": "./dist/reacti8n.cjs",
  "module": "./dist/reacti8n.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/reacti8n.js",
      "require": "./dist/reacti8n.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:example": "vite build --mode example --base /Reacti8n/ && mv dist-example/src/example/index.html dist-example/index.html && rm -rf dist-example/src",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "fmt": "prettier --write .",
    "release": "make checks",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "i18n",
    "react",
    "localization",
    "internationalization",
    "intl",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wildhoney/Reacti8n.git"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "optionalDependencies": {
    "@formatjs/intl-localematcher": "^0.6.1",
    "@formatjs/intl-pluralrules": "^6.3.10"
  },
  "devDependencies": {
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^9.39.3",
    "@formatjs/intl-localematcher": "^0.6.1",
    "@formatjs/intl-pluralrules": "^6.3.10",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.1",
    "antd": "^5.22.5",
    "commit-and-tag-version": "^12.6.1",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-circle-flags": "^0.0.29",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.4.5",
    "vite-plugin-dts": "^4.2.1",
    "vitest": "^2.1.1"
  }
}
